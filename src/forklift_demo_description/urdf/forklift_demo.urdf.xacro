          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.015</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>
  <gazebo reference="rear_lidar_link">
    <sensor name="rear_lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>12</update_rate>
      <visualize>false</visualize>
      <topic>/scan_raw</topic>
      <gz_frame_id>rear_lidar_link</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-0.78539816339</min_angle>
            <max_angle>0.78539816339</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.015</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>
  <gazebo reference="up_lidar_link">
    <sensor name="up_lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>12</update_rate>
      <visualize>false</visualize>
      <topic>/scan_up</topic>
      <gz_frame_id>up_lidar_link</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265359</min_angle>
            <max_angle>3.14159265359</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.015</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>
  <gazebo reference="3d_lidar_link">
    <sensor name="lidar_3d" type="rgbd_camera">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <topic>lidar_3d</topic>
      <gz_frame_id>3d_lidar_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.2287117934</horizontal_fov>
        <image>
          <width>280</width>
          <height>160</height>
        </image>
        <clip>
          <near>0.10</near>
          <far>20.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <gazebo reference="camera_link">
    <sensor name="camera" type="rgbd_camera">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <topic>camera</topic>
      <gz_frame_id>camera_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <gazebo reference="left_lidar_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="right_lidar_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="rear_lidar_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="up_lidar_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="3d_lidar_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="camera_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <mu1>20.0</mu1>
    <mu2>20.0</mu2>
    <slip1>0.03</slip1>
    <slip2>0.03</slip2>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <mu1>20.0</mu1>
    <mu2>20.0</mu2>
    <slip1>0.03</slip1>
    <slip2>0.03</slip2>
  </gazebo>
  <gazebo reference="fork_left_wheel_link">
    <mu1>20.0</mu1>
    <mu2>20.0</mu2>
    <slip1>0.03</slip1>
    <slip2>0.03</slip2>
  </gazebo>
  <gazebo reference="fork_right_wheel_link">
    <mu1>20.0</mu1>
    <mu2>20.0</mu2>
    <slip1>0.03</slip1>
    <slip2>0.03</slip2>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_topic>/odom_gz</odom_topic>
      <tf_topic>/tf_gz</tf_topic>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>30</odom_publish_frequency>
      <dimensions>2</dimensions>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states_gz</topic>
      <joint_name>fork_left_wheel_joint</joint_name>
      <joint_name>fork_right_wheel_joint</joint_name>
      <joint_name>fork_joint</joint_name>
      <joint_name>left_steering_joint</joint_name>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_steering_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>right_steering_joint</joint_name>
      <topic>/forklift/right_steering_cmd</topic>
      <p_gain>80</p_gain>
      <i_gain>0.5</i_gain>
      <d_gain>12</d_gain>
      <i_max>5</i_max>
      <i_min>-5</i_min>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>fork_joint</joint_name>
      <topic>/forklift/fork_velocity_cmd</topic>
      <initial_velocity>0.0</initial_velocity>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>right_wheel_joint</joint_name>
      <topic>/forklift/right_wheel_cmd</topic>
    </plugin>
  </gazebo>
</robot>
